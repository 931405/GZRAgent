# API Keys for different LLM providers

# DeepSeek API (OpenAI compatible)
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DEEPSEEK_API_BASE="https://api.deepseek.com/v1"

# Kimi (Moonshot) API (OpenAI compatible)
MOONSHOT_API_KEY="your_kimi_api_key_here"
MOONSHOT_API_BASE="https://api.moonshot.cn/v1"

# Doubao (Volcengine / OpenAI compatible wrapper)
DOUBAO_API_KEY="your_doubao_api_key_here"
DOUBAO_API_BASE="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_MODEL_ENDPOINT="ep-your-endpoint-id"

# ============ 硅基流动 SiliconFlow (Embedding + 文生图) ============
# Qwen/Qwen3-Embedding-8B 模型 (Embedding)
SILICONFLOW_API_KEY="your_siliconflow_api_key_here"
SILICONFLOW_API_BASE="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL="Qwen/Qwen3-Embedding-8B"

# 文生图模型（默认使用 Stable Diffusion 3.5 Large）
# 可选: stabilityai/stable-diffusion-3-5-large
#       black-forest-labs/FLUX.1-schnell
#       Tencent/HunyuanDiT-v1.2-Diffusers
IMAGE_GEN_MODEL="stabilityai/stable-diffusion-3-5-large"

# ============ 图表生成策略 ============
# DIAGRAM_STRATEGY: mermaid（通过 mermaid.ink 在线渲染，免费，需要网络）
#                   siliconflow（通过文生图 API，需要配置上方 SiliconFlow Key）
#                   both（先 mermaid，失败后 fallback 到 siliconflow）
DIAGRAM_STRATEGY="mermaid"

# Primary model configuration
PRIMARY_PROVIDER="deepseek" # options: deepseek, moonshot, doubao
PRIMARY_MODEL="deepseek-chat"
