# ============================================================
# PD-MAWS Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---------- Application ----------
APP_NAME=PD-MAWS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql+asyncpg://pdmaws:pdmaws_dev_2024@localhost:5433/pdmaws

# ---------- Redis ----------
REDIS_URL=redis://localhost:6380/0

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ---------- JWT Security ----------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- HMAC Message Signing ----------
HMAC_SECRET_KEY=change-me-in-production

# ---------- LLM Providers ----------
# Each agent can be configured with a different provider/model.
# Supported provider types: openai, deepseek, gemini, ollama, custom

# OpenAI (also works for DeepSeek with base_url override)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# DeepSeek (uses OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Google Gemini
GEMINI_API_KEY=xxx
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Custom Provider (private deployment)
CUSTOM_LLM_BASE_URL=http://localhost:8080/v1
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_DEFAULT_MODEL=custom-model

# ---------- Agent LLM Assignments ----------
# Format: AGENT_{NAME}_PROVIDER=provider_type
# Format: AGENT_{NAME}_MODEL=model_name (optional override)
AGENT_PI_PROVIDER=openai
AGENT_PI_MODEL=gpt-4o
AGENT_WRITER_PROVIDER=deepseek
AGENT_WRITER_MODEL=deepseek-chat
AGENT_RESEARCHER_PROVIDER=openai
AGENT_RED_TEAM_PROVIDER=openai
AGENT_DIAGRAM_PROVIDER=openai
AGENT_FORMAT_PROVIDER=deepseek
AGENT_DATA_ANALYST_PROVIDER=openai

# ---------- Token Budget ----------
GLOBAL_TOKEN_HARD_LIMIT=2000000
AGENT_TOKEN_SOFT_LIMIT=200000

# ---------- Observability ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
