# ──────────────────────────────────────────────────────────
# PD-MAWS Backend – Environment Configuration
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── Application ──
APP_NAME=PD-MAWS
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── PostgreSQL ──
DATABASE_URL=postgresql+asyncpg://pdmaws:pdmaws_dev_2024@localhost:5433/pdmaws

# ── Redis ──
REDIS_URL=redis://localhost:6380/0

# ── Qdrant ──
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── JWT Security ──
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── HMAC Message Signing ──
HMAC_SECRET_KEY=change-me-in-production

# ── LLM Provider: OpenAI ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# ── LLM Provider: DeepSeek ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ── LLM Provider: Google Gemini ──
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# ── LLM Provider: Ollama (Local) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── LLM Provider: Custom ──
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_DEFAULT_MODEL=custom-model

# ── Per-Agent LLM Assignment ──
# Available providers: openai, deepseek, gemini, ollama, custom
AGENT_PI_PROVIDER=openai
AGENT_PI_MODEL=
AGENT_WRITER_PROVIDER=deepseek
AGENT_WRITER_MODEL=
AGENT_RESEARCHER_PROVIDER=openai
AGENT_RESEARCHER_MODEL=
AGENT_RED_TEAM_PROVIDER=openai
AGENT_RED_TEAM_MODEL=
AGENT_DIAGRAM_PROVIDER=openai
AGENT_DIAGRAM_MODEL=
AGENT_FORMAT_PROVIDER=deepseek
AGENT_FORMAT_MODEL=
AGENT_DATA_ANALYST_PROVIDER=openai
AGENT_DATA_ANALYST_MODEL=

# ── Token Budget ──
GLOBAL_TOKEN_HARD_LIMIT=2000000
AGENT_TOKEN_SOFT_LIMIT=200000

# ── Observability ──
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
